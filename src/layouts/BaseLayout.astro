---
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import SearchDialog from '@/components/SearchDialog.astro';
import { ClientRouter } from 'astro:transitions';
import { localeFromPath, localizedPath, type Locale } from '@/i18n/config';
import '@/styles/global.css';
import '@pagefind/default-ui/css/ui.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  locale?: Locale;
  hasTranslation?: boolean;
  pageClass?: string;
  immersive?: boolean;
}
const {
  title = 'Renjie — Frontend & AI Engineering',
  description = '前端开发者，关注 AI 编程、Web 工程化与智能应用。分享技术实践、学习笔记和正在构建的项目。',
  image = '/og.png',
  type = 'website',
  noindex = false,
  locale = localeFromPath(Astro.url.pathname),
  hasTranslation = false,
  pageClass,
  immersive = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Renjie') ? title : `${title} — Renjie`;
const imageUrl = image ? new URL(image, Astro.site) : undefined;
const alternateLocale: Locale = locale === 'en' ? 'zh-CN' : 'en';
const directAlternatePath = localizedPath(Astro.url.pathname, alternateLocale);
const fallbackAlternatePath =
  locale === 'en'
    ? '/'
    : Astro.url.pathname.startsWith('/writing')
      ? '/en/writing'
      : '/en/';
const languageHref = hasTranslation
  ? directAlternatePath
  : fallbackAlternatePath;
const zhUrl = new URL(
  locale === 'zh-CN' ? Astro.url.pathname : directAlternatePath,
  Astro.site,
);
const enUrl = new URL(
  locale === 'en' ? Astro.url.pathname : directAlternatePath,
  Astro.site,
);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {
      hasTranslation && (
        <>
          <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
          <link rel="alternate" hreflang="en" href={enUrl} />
          <link rel="alternate" hreflang="x-default" href={zhUrl} />
        </>
      )
    }
    <link rel="icon" href="/img/avatar.png" type="image/png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Renjie Writing"
      href={localizedPath('/rss.xml', locale)}
    />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'zh_CN'} />
    <meta
      property="og:locale:alternate"
      content={locale === 'en' ? 'zh_CN' : 'en_US'}
    />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <title>{fullTitle}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        // 应用主题：优先读取用户选择，否则回退到系统偏好
        const applyTheme = () => {
          const saved = localStorage.getItem('theme');
          const dark =
            saved === 'dark' ||
            (!saved && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        };
        applyTheme();
        // 视图过渡完成、浏览器绘制前重新应用主题，避免切换语言时主题丢失或闪烁
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body class={pageClass}>
    {!immersive && <Header locale={locale} languageHref={languageHref} />}
    <main id="main-content"><slot /></main>
    {!immersive && <Footer locale={locale} />}
    {!immersive && <SearchDialog locale={locale} />}
    <script>
      // 初始化 Header 交互控件（主题切换、移动端菜单）
      function setupHeaderControls() {
        const themeButton =
          document.querySelector<HTMLButtonElement>('.theme-toggle');

        themeButton?.addEventListener('click', () => {
          const next =
            document.documentElement.dataset.theme === 'dark'
              ? 'light'
              : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        });

        const menuButton =
          document.querySelector<HTMLButtonElement>('.menu-toggle');
        const menu = document.querySelector<HTMLElement>('#mobile-menu');

        menuButton?.addEventListener('click', () => {
          if (!menu) return;
          const open = menuButton.getAttribute('aria-expanded') !== 'true';
          menuButton.setAttribute('aria-expanded', String(open));
          menuButton.setAttribute(
            'aria-label',
            open
              ? (menuButton.dataset.closeLabel ?? '')
              : (menuButton.dataset.openLabel ?? ''),
          );
          menu.toggleAttribute('hidden', !open);
        });
      }

      // 首次加载及每次 ClientRouter 导航结束后触发，确保绑定到最新的 Header 节点
      document.addEventListener('astro:page-load', setupHeaderControls);
    </script>
  </body>
</html>
