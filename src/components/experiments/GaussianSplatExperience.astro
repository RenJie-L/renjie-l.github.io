---
import {
  ArrowLeft,
  Expand,
  Languages,
  Move3D,
  Pause,
  Play,
  RotateCcw,
  SlidersHorizontal,
  X,
} from '@lucide/astro';
import type { Locale } from '@/i18n/config';

interface Props {
  locale?: Locale;
}

const { locale = 'zh-CN' } = Astro.props;
const isEnglish = locale === 'en';
const copy = isEnglish
  ? {
      back: 'Back to projects',
      language: '查看中文版本',
      eyebrow: 'Spatial Computing Experiment · 02',
      title: 'Gaussian Splat',
      description:
        'Explore a captured space reconstructed as millions of translucent 3D Gaussians.',
      enter: 'Load 3D scene',
      note: 'SPZ · Spark · Three.js · 7.6 MB',
      loading: 'Loading spatial scene',
      interaction: 'Drag to look · WASD move · Q/E ascend/descend',
      reset: 'Reset view',
      pause: 'Pause rotation',
      play: 'Auto rotate',
      fullscreen: 'Fullscreen',
      failed:
        'The scene could not be loaded. Check WebGL support and try again.',
      panel: {
        toggle: 'Tune',
        title: 'Gaussian Parameters',
        reset: 'Reset to defaults',
        close: 'Close',
        sectionAppearance: 'Appearance',
        opacity: 'Opacity',
        recolor: 'Tint',
        maxSh: 'SH degree',
        sectionRender: 'Rendering',
        maxStdDev: 'Gaussian extent',
        focalAdjustment: 'Sharpness',
        falloff: 'Falloff',
        minAlpha: 'Alpha cutoff',
        minPixelRadius: 'Min pixel radius',
        maxPixelRadius: 'Max pixel radius',
        preBlurAmount: 'Pre-blur',
        sortRadial: 'Radial sorting',
        enable2DGS: '2D Gaussians',
        sectionLod: 'Level of Detail',
        lodSplatScale: 'Detail scale',
        lodRenderScale: 'Min splat pixels',
        sectionDof: 'Depth of Field',
        focalDistance: 'Focus distance',
        apertureAngle: 'Aperture angle',
        sectionFoveation: 'Foveation',
        coneFov0: 'Full-res cone',
        coneFov: 'Falloff cone',
        coneFoveate: 'Edge scale',
        behindFoveate: 'Behind scale',
      },
    }
  : {
      back: '返回项目',
      language: 'View in English',
      eyebrow: '空间计算实验 · 02',
      title: 'Gaussian Splat',
      description: '探索由数百万半透明三维高斯重建而成的真实空间。',
      enter: '加载 3D 场景',
      note: 'SPZ · Spark · Three.js · 7.6 MB',
      loading: '正在加载空间场景',
      interaction: '拖动环视 · WASD 移动 · Q 上升 / E 下降',
      reset: '重置视角',
      pause: '暂停旋转',
      play: '自动旋转',
      fullscreen: '全屏',
      failed: '场景加载失败，请检查浏览器 WebGL 支持后重试。',
      panel: {
        toggle: '调参',
        title: '高斯参数',
        reset: '恢复默认',
        close: '关闭',
        sectionAppearance: '外观',
        opacity: '不透明度',
        recolor: '染色',
        maxSh: '球谐阶数',
        sectionRender: '渲染',
        maxStdDev: '高斯延展',
        focalAdjustment: '锐度',
        falloff: '衰减',
        minAlpha: 'Alpha 截断',
        minPixelRadius: '最小像素半径',
        maxPixelRadius: '最大像素半径',
        preBlurAmount: '预模糊',
        sortRadial: '径向排序',
        enable2DGS: '2D 高斯',
        sectionLod: '细节层次',
        lodSplatScale: '细节倍率',
        lodRenderScale: '最小像素',
        sectionDof: '景深',
        focalDistance: '对焦距离',
        apertureAngle: '光圈角度',
        sectionFoveation: '注视点',
        coneFov0: '全分辨率锥角',
        coneFov: '衰减锥角',
        coneFoveate: '边缘缩放',
        behindFoveate: '后方缩放',
      },
    };
---

<section
  class="splat-experience"
  data-splat-root
  data-state="intro"
  aria-labelledby="splat-title"
>
  <canvas data-splat-canvas aria-label={copy.title}></canvas>
  <div class="ambient" aria-hidden="true"></div>

  <nav
    class="experience-nav"
    aria-label={isEnglish ? 'Experience navigation' : '体验页导航'}
  >
    <a class="nav-pill" href={isEnglish ? '/en/projects' : '/projects'}>
      <ArrowLeft size={16} /><span>{copy.back}</span>
    </a>
    <a
      class="nav-pill"
      href={isEnglish
        ? '/experiments/gaussian-splat'
        : '/en/experiments/gaussian-splat'}
      hreflang={isEnglish ? 'zh-CN' : 'en'}
    >
      <Languages size={16} /><span>{copy.language}</span>
    </a>
  </nav>

  <div class="intro-panel" data-splat-intro>
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1 id="splat-title">{copy.title}</h1>
    <p class="description">{copy.description}</p>
    <button class="enter-button" type="button" data-load-splat>
      <Play size={17} fill="currentColor" />{copy.enter}
    </button>
    <p class="tech-note">{copy.note}</p>
  </div>

  <div class="loader" data-splat-loader hidden aria-live="polite">
    <span class="loader-mark" aria-hidden="true"></span>
    <strong>{copy.loading}</strong>
    <span data-load-status>Preparing renderer…</span>
    <div class="load-track" aria-hidden="true"><span data-load-bar></span></div>
    <span data-load-value>0%</span>
  </div>

  <div class="viewer-hud" data-splat-hud hidden>
    <p><Move3D size={15} />{copy.interaction}</p>
    <div class="viewer-actions">
      <button type="button" data-reset-view title={copy.reset}>
        <RotateCcw size={16} /><span>{copy.reset}</span>
      </button>
      <button
        type="button"
        data-toggle-rotation
        data-playing="true"
        data-play-label={copy.play}
        data-pause-label={copy.pause}
        title={copy.pause}
      >
        <Pause class="pause-icon" size={16} />
        <Play class="play-icon" size={16} />
        <span data-rotation-label>{copy.pause}</span>
      </button>
      <button type="button" data-toggle-panel title={copy.panel.toggle}>
        <SlidersHorizontal size={16} /><span>{copy.panel.toggle}</span>
      </button>
      <button type="button" data-fullscreen title={copy.fullscreen}>
        <Expand size={16} /><span>{copy.fullscreen}</span>
      </button>
    </div>
  </div>

  <aside
    class="splat-panel"
    data-splat-panel
    data-open="false"
    aria-hidden="true"
  >
    <header class="panel-head">
      <h2>{copy.panel.title}</h2>
      <button type="button" data-close-panel title={copy.panel.close}>
        <X size={16} />
      </button>
    </header>

    <div class="panel-body">
      <section class="panel-group">
        <h3>{copy.panel.sectionAppearance}</h3>
        <label class="field">
          <span class="field-label">{copy.panel.opacity}</span>
          <span class="field-value" data-value-for="opacity">1</span>
          <input
            type="range"
            min="0"
            max="1"
            step="0.01"
            data-param="opacity"
          />
        </label>
        <label class="field field-color">
          <span class="field-label">{copy.panel.recolor}</span>
          <input type="color" data-param="recolor" />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.maxSh}</span>
          <select data-param="maxSh">
            <option value="0">0</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
          </select>
        </label>
      </section>

      <section class="panel-group">
        <h3>{copy.panel.sectionRender}</h3>
        <label class="field">
          <span class="field-label">{copy.panel.maxStdDev}</span>
          <span class="field-value" data-value-for="maxStdDev">2.83</span>
          <input
            type="range"
            min="2"
            max="3"
            step="0.01"
            data-param="maxStdDev"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.focalAdjustment}</span>
          <span class="field-value" data-value-for="focalAdjustment">1</span>
          <input
            type="range"
            min="0.5"
            max="3"
            step="0.05"
            data-param="focalAdjustment"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.falloff}</span>
          <span class="field-value" data-value-for="falloff">1</span>
          <input
            type="range"
            min="0"
            max="1"
            step="0.05"
            data-param="falloff"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.minAlpha}</span>
          <span class="field-value" data-value-for="minAlpha">0.002</span>
          <input
            type="range"
            min="0"
            max="0.05"
            step="0.001"
            data-param="minAlpha"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.minPixelRadius}</span>
          <span class="field-value" data-value-for="minPixelRadius">0</span>
          <input
            type="range"
            min="0"
            max="16"
            step="0.5"
            data-param="minPixelRadius"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.maxPixelRadius}</span>
          <span class="field-value" data-value-for="maxPixelRadius">512</span>
          <input
            type="range"
            min="16"
            max="1024"
            step="1"
            data-param="maxPixelRadius"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.preBlurAmount}</span>
          <span class="field-value" data-value-for="preBlurAmount">0</span>
          <input
            type="range"
            min="0"
            max="1"
            step="0.05"
            data-param="preBlurAmount"
          />
        </label>
        <label class="field field-toggle">
          <span class="field-label">{copy.panel.sortRadial}</span>
          <input type="checkbox" data-bool-param="sortRadial" />
        </label>
        <label class="field field-toggle">
          <span class="field-label">{copy.panel.enable2DGS}</span>
          <input type="checkbox" data-bool-param="enable2DGS" />
        </label>
      </section>

      <section class="panel-group">
        <h3>{copy.panel.sectionLod}</h3>
        <label class="field">
          <span class="field-label">{copy.panel.lodSplatScale}</span>
          <span class="field-value" data-value-for="lodSplatScale">1</span>
          <input
            type="range"
            min="0.25"
            max="4"
            step="0.05"
            data-param="lodSplatScale"
          />
        </label>
        <label class="field">
          <span class="field-label">{copy.panel.lodRenderScale}</span>
          <span class="field-value" data-value-for="lodRenderScale">1</span>
          <input
            type="range"
            min="1"
            max="5"
            step="0.5"
            data-param="lodRenderScale"
          />
        </label>
      </section>

      <section class="panel-group" data-collapsible data-collapsed="true">
        <h3 data-collapse-trigger>{copy.panel.sectionDof}</h3>
        <div class="panel-group-body">
          <label class="field">
            <span class="field-label">{copy.panel.focalDistance}</span>
            <span class="field-value" data-value-for="focalDistance">0</span>
            <input
              type="range"
              min="0"
              max="50"
              step="0.5"
              data-param="focalDistance"
            />
          </label>
          <label class="field">
            <span class="field-label">{copy.panel.apertureAngle}</span>
            <span class="field-value" data-value-for="apertureAngle">0</span>
            <input
              type="range"
              min="0"
              max="0.5"
              step="0.01"
              data-param="apertureAngle"
            />
          </label>
        </div>
      </section>

      <section class="panel-group" data-collapsible data-collapsed="true">
        <h3 data-collapse-trigger>{copy.panel.sectionFoveation}</h3>
        <div class="panel-group-body">
          <label class="field">
            <span class="field-label">{copy.panel.coneFov0}</span>
            <span class="field-value" data-value-for="coneFov0">90</span>
            <input
              type="range"
              min="30"
              max="120"
              step="5"
              data-param="coneFov0"
            />
          </label>
          <label class="field">
            <span class="field-label">{copy.panel.coneFov}</span>
            <span class="field-value" data-value-for="coneFov">120</span>
            <input
              type="range"
              min="60"
              max="180"
              step="5"
              data-param="coneFov"
            />
          </label>
          <label class="field">
            <span class="field-label">{copy.panel.coneFoveate}</span>
            <span class="field-value" data-value-for="coneFoveate">0.4</span>
            <input
              type="range"
              min="0"
              max="1"
              step="0.05"
              data-param="coneFoveate"
            />
          </label>
          <label class="field">
            <span class="field-label">{copy.panel.behindFoveate}</span>
            <span class="field-value" data-value-for="behindFoveate">0.2</span>
            <input
              type="range"
              min="0"
              max="1"
              step="0.05"
              data-param="behindFoveate"
            />
          </label>
        </div>
      </section>
    </div>

    <footer class="panel-foot">
      <button type="button" data-panel-reset>{copy.panel.reset}</button>
    </footer>
  </aside>

  <p class="error-message" data-splat-error hidden role="alert">
    {copy.failed}
  </p>
  <noscript
    ><p class="error-message">This viewer requires JavaScript.</p></noscript
  >
</section>

<script>
  import type { GaussianSplatScene } from '@/scripts/gaussian-splat/GaussianSplatScene';
  import type { GaussianSplatPanel } from '@/scripts/gaussian-splat/GaussianSplatPanel';

  let splatScene: GaussianSplatScene | undefined;
  let splatPanel: GaussianSplatPanel | undefined;

  function setupSplatExperience() {
    const root = document.querySelector<HTMLElement>('[data-splat-root]');
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';
    const loadButton =
      root.querySelector<HTMLButtonElement>('[data-load-splat]');
    const intro = root.querySelector<HTMLElement>('[data-splat-intro]');
    const loader = root.querySelector<HTMLElement>('[data-splat-loader]');
    const hud = root.querySelector<HTMLElement>('[data-splat-hud]');
    const errorMessage = root.querySelector<HTMLElement>('[data-splat-error]');
    const loadBar = root.querySelector<HTMLElement>('[data-load-bar]');
    const loadValue = root.querySelector<HTMLElement>('[data-load-value]');
    const loadStatus = root.querySelector<HTMLElement>('[data-load-status]');
    const rotationButton = root.querySelector<HTMLButtonElement>(
      '[data-toggle-rotation]',
    );
    const panelEl = root.querySelector<HTMLElement>('[data-splat-panel]');

    const updateRotationButton = (playing: boolean) => {
      if (!rotationButton) return;
      const playLabel = rotationButton.dataset.playLabel ?? 'Auto rotate';
      const pauseLabel = rotationButton.dataset.pauseLabel ?? 'Pause rotation';
      rotationButton.dataset.playing = String(playing);
      rotationButton.title = playing ? pauseLabel : playLabel;
      const label = rotationButton.querySelector('[data-rotation-label]');
      if (label) label.textContent = playing ? pauseLabel : playLabel;
    };

    root.addEventListener('splat-auto-rotate-change', (event) => {
      updateRotationButton((event as CustomEvent<boolean>).detail);
    });

    loadButton?.addEventListener('click', async () => {
      loadButton.disabled = true;
      root.dataset.state = 'loading';
      loader?.removeAttribute('hidden');
      try {
        const [{ GaussianSplatScene }, { GaussianSplatPanel }] =
          await Promise.all([
            import('@/scripts/gaussian-splat/GaussianSplatScene'),
            import('@/scripts/gaussian-splat/GaussianSplatPanel'),
          ]);
        splatScene = new GaussianSplatScene(root);
        await splatScene.init((progress, status) => {
          if (loadBar) loadBar.style.width = `${progress}%`;
          if (loadValue) loadValue.textContent = `${progress}%`;
          if (loadStatus) loadStatus.textContent = status;
        });
        splatPanel = new GaussianSplatPanel(root, (p) =>
          splatScene?.applyParams(p),
        );
        panelEl?.setAttribute('aria-hidden', 'false');
        root.dataset.state = 'active';
        intro?.setAttribute('hidden', '');
        loader?.setAttribute('hidden', '');
        hud?.removeAttribute('hidden');
        splatScene.start();
      } catch (error) {
        console.warn('Unable to load Gaussian splat scene.', error);
        root.dataset.state = 'error';
        loader?.setAttribute('hidden', '');
        errorMessage?.removeAttribute('hidden');
        loadButton.disabled = false;
      }
    });

    root.querySelector('[data-reset-view]')?.addEventListener('click', () => {
      splatScene?.resetView();
    });
    rotationButton?.addEventListener('click', () => {
      splatScene?.toggleAutoRotate();
    });
    root.querySelector('[data-toggle-panel]')?.addEventListener('click', () => {
      splatPanel?.toggle();
    });
    root.querySelector('[data-close-panel]')?.addEventListener('click', () => {
      splatPanel?.setOpen(false);
    });
    root.querySelector('[data-fullscreen]')?.addEventListener('click', () => {
      if (document.fullscreenElement) void document.exitFullscreen();
      else void root.requestFullscreen();
    });
  }

  function destroySplatExperience() {
    splatPanel?.dispose();
    splatPanel = undefined;
    splatScene?.destroy();
    splatScene = undefined;
  }

  document.addEventListener('astro:page-load', setupSplatExperience);
  document.addEventListener('astro:before-swap', destroySplatExperience);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupSplatExperience, {
      once: true,
    });
  } else {
    setupSplatExperience();
  }
</script>

<style>
  :global(.gaussian-splat-page) {
    overflow: hidden;
    background: #090b0f;
  }
  :global(.gaussian-splat-page main) {
    min-height: 100svh;
  }
  .splat-experience {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    overflow: hidden;
    color: #f5f4ef;
    background: #090b0f;
  }
  .splat-experience::before {
    position: absolute;
    z-index: -3;
    inset: 0;
    background:
      url('//qhstaticssl.kujiale.com/image/png/1784796389707/2AD7DC892E5ED414DBC4BC20F6BEF4D6.png?imageMogr2/format/webp')
        center / cover no-repeat,
      #090b0f;
    content: '';
    opacity: 0.9;
    transform: scale(1.015);
    transition:
      opacity 0.8s ease,
      transform 1.4s ease;
  }
  [data-state='active'].splat-experience::before {
    opacity: 0;
    transform: scale(1);
  }
  [data-splat-canvas],
  .ambient {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  [data-splat-canvas] {
    z-index: -2;
    opacity: 0;
    touch-action: none;
    transition: opacity 0.8s ease;
  }
  [data-state='active'] [data-splat-canvas] {
    opacity: 1;
  }
  .ambient {
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(
        circle at 72% 22%,
        rgb(76 107 113 / 10%),
        transparent 38%
      ),
      linear-gradient(
        90deg,
        rgb(9 11 15 / 96%) 0%,
        rgb(9 11 15 / 88%) 34%,
        rgb(9 11 15 / 34%) 62%,
        rgb(9 11 15 / 8%) 100%
      );
  }
  [data-state='active'] .ambient {
    background: linear-gradient(
      180deg,
      rgb(9 11 15 / 34%),
      transparent 28% 72%,
      rgb(9 11 15 / 48%)
    );
  }
  .experience-nav {
    position: absolute;
    z-index: 4;
    top: max(1.2rem, env(safe-area-inset-top));
    left: max(1.2rem, env(safe-area-inset-left));
    right: max(1.2rem, env(safe-area-inset-right));
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }
  .nav-pill,
  .viewer-actions button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 42px;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgb(255 255 255 / 15%);
    border-radius: 999px;
    color: #f5f4ef;
    background: rgb(12 15 20 / 74%);
    box-shadow: 0 12px 32px rgb(0 0 0 / 20%);
    backdrop-filter: blur(14px);
    font-size: 0.78rem;
    pointer-events: auto;
  }
  .nav-pill:hover,
  .viewer-actions button:hover {
    border-color: rgb(255 255 255 / 34%);
    background: rgb(25 30 37 / 86%);
  }
  .intro-panel {
    position: absolute;
    z-index: 3;
    top: 50%;
    left: max(7vw, 1.5rem);
    width: min(560px, calc(100% - 3rem));
    transform: translateY(-46%);
  }
  .eyebrow {
    color: #7fc7ca;
    font:
      650 0.72rem ui-monospace,
      monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  h1 {
    margin: 0.65rem 0 1rem;
    font-size: clamp(3.8rem, 10vw, 8.5rem);
    line-height: 0.85;
    letter-spacing: -0.075em;
  }
  .description {
    max-width: 510px;
    color: rgb(245 244 239 / 68%);
    font-size: clamp(1rem, 2vw, 1.25rem);
  }
  .enter-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.5rem;
    padding: 0.85rem 1.15rem;
    border: 0;
    border-radius: 12px;
    color: #081012;
    background: #a7e3df;
    font-weight: 700;
    cursor: pointer;
  }
  .enter-button:hover {
    background: #c3f2ed;
    transform: translateY(-1px);
  }
  .enter-button:disabled {
    opacity: 0.55;
    cursor: wait;
  }
  .tech-note {
    color: rgb(245 244 239 / 42%);
    font:
      0.72rem ui-monospace,
      monospace;
  }
  .loader {
    position: absolute;
    z-index: 4;
    top: 50%;
    left: 50%;
    display: grid;
    justify-items: center;
    gap: 0.65rem;
    width: min(320px, calc(100% - 3rem));
    padding: 1.4rem;
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 16px;
    background: rgb(12 15 20 / 84%);
    backdrop-filter: blur(18px);
    transform: translate(-50%, -50%);
    text-align: center;
  }
  .loader-mark {
    width: 34px;
    height: 34px;
    border: 2px solid rgb(167 227 223 / 20%);
    border-top-color: #a7e3df;
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  .loader > span:not(.loader-mark) {
    color: rgb(245 244 239 / 56%);
    font-size: 0.75rem;
  }
  .load-track {
    overflow: hidden;
    width: 100%;
    height: 3px;
    border-radius: 99px;
