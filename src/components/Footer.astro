---
import { localizedPath, type Locale, ui } from '@/i18n/config';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const year = new Date().getFullYear();
const t = ui[locale];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div><strong>Renjie</strong><p>{t.footerTagline}</p></div>
    <div class="footer-links">
      <a href={localizedPath('/rss.xml', locale)}>RSS</a><a
        href="mailto:renjie-l@foxmail.com">Email</a
      ><a href="https://github.com/RenJie-L" target="_blank" rel="noreferrer"
        >GitHub</a
      >
    </div>
  </div>
  <p class="copyright">© {year} Renjie. Built with Astro.</p>
</footer>
