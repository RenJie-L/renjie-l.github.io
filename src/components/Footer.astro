---
import { localizedPath, type Locale, ui } from '@/i18n/config';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const year = new Date().getFullYear();
const t = ui[locale];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-identity">
      <p class="footer-signature">
        <strong>Renjie</strong>
        <span class="footer-dot" aria-hidden="true">·</span>
        <span>{t.footerTagline}</span>
      </p>
      <p class="copyright">© {year} Renjie. Built with Astro.</p>
    </div>
    <div class="footer-side">
      <nav
        class="footer-links"
        aria-label={locale === 'en' ? 'Footer links' : '页脚链接'}
      >
        <a href={localizedPath('/rss.xml', locale)}>RSS</a><a
          href="mailto:renjie-l@foxmail.com">Email</a
        >
      </nav>
      <!-- 保留统计节点继续累计数据，访问量达到展示条件后移除 hidden 即可。 -->
      <p class="site-stats" aria-live="polite" hidden>
        <span id="busuanzi_container_site_pv" style="display: none;">
          {locale === 'en' ? 'Total views' : '总访问量'}
          <span id="busuanzi_value_site_pv"></span>
          {locale === 'en' ? '' : ' 次'}
        </span>
        <span id="busuanzi_container_site_uv" style="display: none;">
          <span class="stats-separator" aria-hidden="true">·</span>
          {locale === 'en' ? 'Total visitors' : '总访客数'}
          <span id="busuanzi_value_site_uv"></span>
          {locale === 'en' ? '' : ' 人'}
        </span>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding: 2.25rem 0;
    margin-top: 7rem;
    color: var(--muted);
  }
  .footer-inner {
    width: min(calc(100% - 2rem), var(--max));
    margin: auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }
  .footer-identity,
  .footer-side {
    display: grid;
    gap: 0.55rem;
  }
  .footer-signature {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
  }
  .footer-inner strong {
    color: var(--text);
  }
  .footer-dot {
    color: var(--line);
  }
  .footer-side {
    justify-items: end;
  }
  .footer-links {
    display: flex;
    gap: 1.25rem;
  }
  .footer-links a:hover {
    color: var(--text);
  }
  .copyright,
  .site-stats {
    margin: 0;
    font-size: 0.82rem;
  }
  .site-stats {
    text-align: right;
  }
  .stats-separator {
    margin-inline: 0.35rem;
  }

  @media (max-width: 760px) {
    .footer-inner {
      align-items: stretch;
      flex-direction: column;
      gap: 1.35rem;
    }
    .footer-side {
      justify-items: start;
    }
    .site-stats {
      text-align: left;
    }
  }
</style>

<script
  is:inline
  data-astro-rerun
  defer
  src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"
></script>
