<dialog class="search-dialog" aria-labelledby="search-title">
  <div class="search-panel">
    <div class="search-heading">
      <h2 id="search-title">搜索文章</h2><button
        class="search-close"
        aria-label="关闭搜索">Esc</button
      >
    </div>
    <div id="search"></div>
    <noscript>请启用 JavaScript 使用站内搜索。</noscript>
  </div>
</dialog>

<script>
  let initialized = false;
  const dialog = document.querySelector<HTMLDialogElement>('.search-dialog');
  const openSearch = async () => {
    if (!dialog) return;
    dialog.showModal();
    document.body.classList.add('dialog-open');
    if (!initialized) {
      try {
        const { PagefindUI } = await import('@pagefind/default-ui');
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations: {
            placeholder: '搜索标题、标签或正文…',
            zero_results: '没有找到相关内容',
          },
        });
        initialized = true;
      } catch {
        document.querySelector('#search')!.textContent =
          '搜索索引将在生产构建后可用。';
      }
    }
    setTimeout(
      () => dialog.querySelector<HTMLInputElement>('input')?.focus(),
      50,
    );
  };
  document
    .querySelector('.search-trigger')
    ?.addEventListener('click', openSearch);
  document
    .querySelector('.search-close')
    ?.addEventListener('click', () => dialog?.close());
  dialog?.addEventListener('close', () =>
    document.body.classList.remove('dialog-open'),
  );
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) dialog.close();
  });
  document.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      openSearch();
    }
  });
</script>
