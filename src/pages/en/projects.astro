---
import { ArrowRight, ExternalLink } from '@lucide/astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  locale="en"
  hasTranslation
  title="Projects"
  description="Selected engineering and research projects by Renjie."
>
  <div class="page-intro">
    <div class="container">
      <p class="eyebrow">Projects</p><h1>Projects</h1><p>
        Turning research questions and engineering ideas into verifiable,
        maintainable outcomes.
      </p>
    </div>
  </div>
  <section class="project-list container">
    <article class="project-card">
      <div class="project-head">
        <div>
          <span>2026.07 — Present · Creative Developer</span>
          <h2>3D Gaussian Splat Scene Viewer</h2>
          <p>
            A focused browser experiment for loading and exploring a compressed
            SPZ spatial capture with Spark and Three.js.
          </p>
        </div>
        <div class="project-links">
          <a class="project-action" href="/en/experiments/gaussian-splat">
            Enter scene <ArrowRight size={14} />
          </a>
        </div>
      </div>
      <ul>
        <li>Loads a remote 7.6 MB SPZ scene directly in the browser.</li>
        <li>
          Orbit, zoom, pan, auto-rotation, reset, and fullscreen controls.
        </li>
        <li>Viewer code and scene data are loaded only after user intent.</li>
      </ul>
      <div class="technologies">
        <span>3DGS</span><span>SPZ</span><span>Spark</span><span>Three.js</span
        ><span>Astro</span>
      </div>
    </article>
    <article class="project-card has-cover">
      <a
        class="project-cover"
        href="/en/experiments/west-lake"
        aria-label="Enter West Lake WebGL Experience"
      >
        <img
          src="//qhstaticssl.kujiale.com/image/png/1784635482363/DE063287279A2D3B475758E3E2C9712F.png?imageMogr2/format/webp"
          alt="Ink-wash West Lake with a stone bridge, distant mountains, and a pagoda"
          loading="lazy"
        />
      </a>
      <div class="project-head">
        <div>
          <span>2026.07 — Present · Creative Developer</span>
          <h2>West Lake: A Digital Ink-Wash WebGL Experience</h2>
          <p>
            An original real-time landscape built with procedural mountains,
            water shaders, mist, and restrained interaction.
          </p>
        </div>
        <div class="project-links">
          <a class="project-action" href="/en/experiments/west-lake">
            Enter scene <ArrowRight size={14} />
          </a>
        </div>
      </div>
      <ul>
        <li>
          Procedural landscape, lake shader, atmospheric mist, and particles.
        </li>
        <li>Full, Lite, and reduced-motion presentation modes.</li>
        <li>Loaded only after the visitor chooses to enter the experience.</li>
      </ul>
      <div class="technologies">
        <span>Three.js</span><span>WebGL</span><span>GLSL</span><span>GSAP</span
        ><span>Astro</span>
      </div>
    </article>
    <article class="project-card has-cover">
      <a
        class="project-cover"
        href="https://ieeexplore.ieee.org/abstract/document/10055333"
        target="_blank"
        rel="noreferrer"
        aria-label="Read the UAV swing-free trajectory planning publication"
      >
        <img
          src="//qhstaticssl.kujiale.com/image/png/1784635477373/1D4A17E9B264CA306E1E28A789EF5470.png?imageMogr2/format/webp"
          alt="A quadrotor follows a planned trajectory toward a target region while its suspended payload swing settles"
          loading="lazy"
        />
      </a>
      <div class="project-head">
        <div>
          <span>2022.03 — 2023.06 · First Author / Researcher</span><h2>
            Reinforcement Learning for Swing-Free UAV Trajectories
          </h2><p>
            A DQN-based trajectory planner that balances travel efficiency and
            swing suppression for a quadrotor carrying a cable-suspended load.
          </p>
        </div>
        <div class="project-links">
          <a
            class="project-action secondary"
            href="https://ieeexplore.ieee.org/abstract/document/10055333"
            target="_blank"
            rel="noreferrer">Publication <ExternalLink size={14} /></a
          >
        </div>
      </div>
      <ul>
        <li>
          Reduced the coupled, nonlinear, underactuated system to planar motion
          and built a six-state, Gym-compatible simulator.
        </li>
        <li>
          Combined a discrete action space with DQN, experience replay, and
          separate main and target networks.
        </li>
        <li>
          Designed a region-approximation exploration reward that progressively
          balances target distance against payload swing.
        </li>
        <li>
          Converged at about 600 of 850 training episodes; across 20 simulation
          tests, peak swing stayed within 16° and angular speed within 46°/s.
        </li>
      </ul>
      <div class="technologies">
        <span>DQN</span><span>Reinforcement Learning</span><span
          >Trajectory Planning</span
        ><span>PyTorch</span><span>OpenAI Gym</span>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .project-list {
    display: grid;
    gap: 1.25rem;
    padding-top: 3rem;
  }
  .project-card {
    --card-padding: clamp(1.4rem, 4vw, 2.2rem);
    overflow: hidden;
    padding: var(--card-padding);
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--surface);
  }
  .project-card.has-cover {
    display: block;
  }
  .project-cover {
    display: block;
    overflow: hidden;
    margin: calc(var(--card-padding) * -1);
    margin-bottom: var(--card-padding);
    aspect-ratio: 1200 / 630;
    background: var(--surface-2);
  }
  .has-cover .project-cover {
    position: relative;
    margin: calc(var(--card-padding) * -1);
    margin-bottom: 0;
    aspect-ratio: 1200 / 630;
  }
  .has-cover .project-cover::after {
    position: absolute;
    inset: 50% 0 0;
    background: linear-gradient(to bottom, transparent 0%, var(--surface) 100%);
    content: '';
    pointer-events: none;
  }
  .project-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-cover:hover img {
    transform: scale(1.025);
  }
  .project-head {
    display: block;
  }
  .has-cover .project-head {
    position: relative;
    z-index: 1;
    margin-top: clamp(-7rem, -10vw, -5rem);
  }
  .project-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin-top: 1rem;
  }
  .project-action {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.42rem 0.8rem;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    border-radius: 9px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 650;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }
  .project-action:hover {
    border-color: color-mix(in srgb, var(--accent) 48%, var(--line));
    transform: translateY(-1px);
  }
  .project-action.secondary {
    min-height: auto;
    padding: 0.35rem 0.1rem;
    border: 0;
    background: transparent;
    color: var(--muted);
    font-weight: 560;
  }
  .project-action.secondary:hover {
    color: var(--text);
  }
  .project-head span {
    color: var(--accent);
    font:
      600 0.78rem ui-monospace,
      monospace;
  }
  .project-card h2 {
    margin: 0.45rem 0;
    font-size: 1.45rem;
    letter-spacing: -0.025em;
  }
  .project-card p,
  .project-card ul {
    color: var(--muted);
  }
  .project-card p {
    max-width: 700px;
    margin: 0;
  }
  .project-card ul {
    padding-left: 1.25rem;
    margin: 1.7rem 0;
  }
  .has-cover > ul {
    margin: 1.35rem 0;
  }
  .technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }
  .technologies span {
    color: var(--muted);
    font-size: 0.78rem;
  }
  .technologies span:not(:last-child)::after {
    content: ' /';
    color: var(--line);
  }
  @media (max-width: 640px) {
    .has-cover .project-head {
      margin-top: -4.5rem;
    }
  }
</style>
