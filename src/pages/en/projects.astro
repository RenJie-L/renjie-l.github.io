---
import { ExternalLink } from '@lucide/astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  locale="en"
  hasTranslation
  title="Projects"
  description="Selected engineering and research projects by Renjie."
>
  <div class="page-intro">
    <div class="container">
      <p class="eyebrow">Projects</p><h1>Projects</h1><p>
        Turning research questions and engineering ideas into verifiable,
        maintainable outcomes.
      </p>
    </div>
  </div>
  <section class="project-list container">
    <article class="project-card">
      <div class="project-head">
        <div>
          <span>2026.07 — Present · Creative Developer</span>
          <h2>3D Gaussian Splat Scene Viewer</h2>
          <p>
            A focused browser experiment for loading and exploring a compressed
            SPZ spatial capture with Spark and Three.js.
          </p>
        </div>
        <a class="button" href="/en/experiments/gaussian-splat">
          Enter scene <ExternalLink size={14} />
        </a>
      </div>
      <ul>
        <li>Loads a remote 7.6 MB SPZ scene directly in the browser.</li>
        <li>
          Orbit, zoom, pan, auto-rotation, reset, and fullscreen controls.
        </li>
        <li>Viewer code and scene data are loaded only after user intent.</li>
      </ul>
      <div class="technologies">
        <span>3DGS</span><span>SPZ</span><span>Spark</span><span>Three.js</span
        ><span>Astro</span>
      </div>
    </article>
    <article class="project-card">
      <a
        class="project-cover"
        href="/en/experiments/west-lake"
        aria-label="Enter West Lake WebGL Experience"
      >
        <img
          src="/experiments/west-lake/poster.png"
          alt="Ink-wash West Lake with a stone bridge, distant mountains, and a pagoda"
          loading="lazy"
        />
      </a>
      <div class="project-head">
        <div>
          <span>2026.07 — Present · Creative Developer</span>
          <h2>West Lake: A Digital Ink-Wash WebGL Experience</h2>
          <p>
            An original real-time landscape built with procedural mountains,
            water shaders, mist, and restrained interaction.
          </p>
        </div>
        <a class="button" href="/en/experiments/west-lake">
          Enter scene <ExternalLink size={14} />
        </a>
      </div>
      <ul>
        <li>
          Procedural landscape, lake shader, atmospheric mist, and particles.
        </li>
        <li>Full, Lite, and reduced-motion presentation modes.</li>
        <li>Loaded only after the visitor chooses to enter the experience.</li>
      </ul>
      <div class="technologies">
        <span>Three.js</span><span>WebGL</span><span>GLSL</span><span>GSAP</span
        ><span>Astro</span>
      </div>
    </article>
    <article class="project-card">
      <div class="project-head">
        <div>
          <span>2022.03 — 2023.06 · Researcher / Engineer</span><h2>
            Reinforcement Learning for Swing-Free UAV Trajectories
          </h2><p>
            A deep reinforcement learning approach to generate trajectories that
            reduce suspended-load swing, validated on a physical UAV system.
          </p>
        </div>
        <a
          class="button"
          href="https://ieeexplore.ieee.org/"
          target="_blank"
          rel="noreferrer">Publication <ExternalLink size={14} /></a
        >
      </div>
      <ul>
        <li>Modeled trajectory planning for a UAV with a suspended load.</li><li
        >
          Explored swing-free trajectory generation with deep reinforcement
          learning.
        </li><li>Validated the approach on a physical UAV system.</li>
      </ul>
      <div class="technologies">
        <span>Reinforcement Learning</span><span>Trajectory Planning</span><span
          >UAV</span
        ><span>Python</span>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .project-list {
    display: grid;
    gap: 1.25rem;
    padding-top: 3rem;
  }
  .project-card {
    overflow: hidden;
    padding: clamp(1.4rem, 4vw, 2.2rem);
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--surface);
  }
  .project-cover {
    display: block;
    overflow: hidden;
    margin: calc(clamp(1.4rem, 4vw, 2.2rem) * -1);
    margin-bottom: clamp(1.4rem, 4vw, 2.2rem);
    aspect-ratio: 1200 / 630;
    background: var(--surface-2);
  }
  .project-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-cover:hover img {
    transform: scale(1.025);
  }
  .project-head {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }
  .project-head span {
    color: var(--accent);
    font:
      600 0.78rem ui-monospace,
      monospace;
  }
  .project-card h2 {
    margin: 0.45rem 0;
    font-size: 1.45rem;
    letter-spacing: -0.025em;
  }
  .project-card p,
  .project-card ul {
    color: var(--muted);
  }
  .project-card p {
    max-width: 700px;
    margin: 0;
  }
  .project-card ul {
    padding-left: 1.25rem;
    margin: 1.7rem 0;
  }
  .technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }
  .technologies span {
    color: var(--muted);
    font-size: 0.78rem;
  }
  .technologies span:not(:last-child)::after {
    content: ' /';
    color: var(--line);
  }
  @media (max-width: 640px) {
    .project-head {
      flex-direction: column;
    }
  }
</style>
