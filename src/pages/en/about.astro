---
import { Mail } from '@lucide/astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  locale="en"
  hasTranslation
  title="About"
  description="About Renjie, a frontend engineer exploring AI agents and reinforcement learning."
>
  <div class="page-intro">
    <div class="container">
      <p class="eyebrow">About</p><h1>
        Connecting ideas to reality through engineering.
      </h1>
    </div>
  </div>
  <div class="about-layout container">
    <aside>
      <p class="about-lede">
        I'm Renjie, a frontend engineer exploring AI-assisted development, agent
        engineering, and reinforcement learning. I enjoy breaking down complex
        problems and turning them into reliable, useful products.
      </p><div class="contact-links">
        <a class="button" href="mailto:renjie-l@foxmail.com"
          ><Mail size={16} /> Email</a
        >
      </div>
    </aside>
    <div class="about-content">
      <section>
        <p class="eyebrow">Focus</p><h2>Areas of focus</h2><div
          class="focus-tags"
        >
          <span>Frontend Engineering</span><span>React / TypeScript</span><span
            >AI-assisted Development</span
          ><span>AI Agent Engineering</span><span>Developer Experience</span
          ><span>Reinforcement Learning</span>
        </div>
      </section>
      <section>
        <p class="eyebrow">Education</p><h2>Education</h2><div class="timeline">
          <article>
            <span>2020.09 — 2023.06</span><h3>Hangzhou Dianzi University</h3><p>
              M.Eng. · Electronic Information
            </p>
          </article><article>
            <span>2020.09 — 2022.06</span><h3>ITMO University</h3><p>
              Master · Control Engineering
            </p>
          </article>
        </div>
      </section>
      <section>
        <p class="eyebrow">Research</p><h2>Research & practice</h2><article
          class="detail-card"
        >
          <span>2022.03 — 2023.06</span><h3>
            Swing-Free Trajectory Generation for UAV Suspended Loads
          </h3><p>
            A research project using reinforcement learning to generate
            swing-free flight trajectories and validate them on a physical UAV
            platform.
          </p>
        </article>
      </section>
      <section>
        <p class="eyebrow">Publication</p><h2>Publication</h2><p
          class="publication"
        >
          Renjie, L., & Fan, Y. (2022). Deep Reinforcement Learning-based
          Swing-Free Trajectories Planning Algorithm for UAV with a Suspended
          Load. <em>China Automation Congress 2022.</em>
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(3rem, 8vw, 8rem);
    padding-top: 4rem;
  }
  aside {
    align-self: start;
    position: sticky;
    top: 7rem;
  }
  .about-lede {
    font-size: 1.2rem;
    line-height: 1.8;
    margin: 0;
  }
  .contact-links {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }
  .about-content {
    display: grid;
    gap: 4.5rem;
  }
  section h2 {
    margin: 0 0 1.3rem;
    font-size: 1.45rem;
  }
  .focus-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .focus-tags span {
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 9px;
    font-size: 0.83rem;
  }
  .timeline {
    border-left: 1px solid var(--line);
    padding-left: 1.5rem;
    display: grid;
    gap: 1.8rem;
  }
  .timeline article {
    position: relative;
  }
  .timeline article::before {
    content: '';
    position: absolute;
    left: calc(-1.5rem - 4px);
    top: 0.5rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }
  .timeline span,
  .detail-card > span {
    color: var(--accent);
    font:
      600 0.75rem ui-monospace,
      monospace;
  }
  .timeline h3,
  .detail-card h3 {
    margin: 0.3rem 0;
    font-size: 1rem;
  }
  .timeline p,
  .detail-card p,
  .publication {
    color: var(--muted);
    margin: 0;
  }
  .detail-card {
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--surface);
  }
  @media (max-width: 760px) {
    .about-layout {
      grid-template-columns: 1fr;
    }
    aside {
      position: static;
    }
  }
</style>
