---
import { ArrowRight, Bot, Braces, Sparkles, Wrench } from '@lucide/astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const directions = [
  {
    icon: Braces,
    title: 'Frontend Engineering',
    text: 'React, TypeScript, and web architecture built to evolve.',
  },
  {
    icon: Bot,
    title: 'AI Agent Engineering',
    text: 'Agent workflows, context engineering, and intelligent applications.',
  },
  {
    icon: Wrench,
    title: 'Developer Experience',
    text: 'Tools and workflows that help teams build with less friction.',
  },
];
---

<BaseLayout
  locale="en"
  hasTranslation
  title="Renjie — Frontend & AI Engineering"
  description="Frontend engineer exploring AI-assisted development, web engineering, and intelligent applications."
>
  <section class="hero container">
    <div class="hero-copy">
      <p class="availability">
        <span></span> Currently exploring AI Agent Engineering
      </p>
      <h1>Hi, I'm Renjie.</h1>
      <p class="hero-lede">
        Frontend engineer focused on AI-assisted development, web engineering,
        and intelligent applications.<br />I share technical practice, learning
        notes, and the projects I am building.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/en/writing"
          >Explore writing <ArrowRight size={16} /></a
        >
        <a class="button" href="/en/about">About me</a>
      </div>
    </div>
    <div class="hero-signal" aria-hidden="true">
      <span class="signal-label">Current stack</span>
      <div class="signal-row">
        <span>React</span><span>TypeScript</span><span>Astro</span>
      </div>
      <div class="signal-row offset">
        <span>Agent</span><span>RL</span><span>DX</span>
      </div>
    </div>
  </section>

  <section id="current-focus" class="focus-strip">
    <div class="focus-inner container">
      <div><p class="eyebrow">Now</p><h2>Current focus</h2></div>
      <p>
        Exploring how AI agents can understand, plan, and deliver in large
        software projects—and turning those lessons into reusable engineering
        practices.
      </p>
      <Sparkles size={22} />
    </div>
  </section>

  <section class="section container">
    <div class="section-heading">
      <div><p class="eyebrow">What I work on</p><h2>Technical focus</h2></div>
    </div>
    <div class="direction-grid">
      {
        directions.map(({ icon: Icon, title, text }) => (
          <article class="direction-card">
            <div class="direction-icon">
              <Icon size={21} />
            </div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section container">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected project</p><h2>Research in practice</h2>
      </div>
      <a class="text-link" href="/en/projects"
        >View projects <ArrowRight size={15} /></a
      >
    </div>
    <div class="project-feature-list">
      <article class="project-feature">
        <div>
          <span class="project-period">2026.07 — Present</span>
          <h3>West Lake WebGL Experience</h3>
          <p>
            An original digital ink-wash landscape built with procedural
            geometry and shaders.
          </p>
          <a class="project-entry" href="/en/experiments/west-lake">
            Enter scene <ArrowRight size={14} />
          </a>
        </div>
        <div class="tech-list">
          <span>Three.js</span><span>GLSL</span><span>GSAP</span>
        </div>
      </article>
      <article class="project-feature">
        <div>
          <span class="project-period">2022.03 — 2023.06</span>
          <h3>Reinforcement Learning for Swing-Free UAV Trajectories</h3>
          <p>
            A deep reinforcement learning approach for planning trajectories
            that reduce suspended-load swing, validated on a physical UAV
            system.
          </p>
        </div>
        <div class="tech-list">
          <span>RL</span><span>UAV</span><span>Python</span>
        </div>
      </article>
    </div>
  </section>

  <section class="section writing-cta container">
    <p class="eyebrow">Writing</p>
    <h2>English articles are on the way.</h2>
    <p>
      The site interface is now bilingual. English translations of selected
      articles will be published gradually.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="/en/writing">English writing</a>
      <a class="button" href="/writing" hreflang="zh-CN">Read in Chinese</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 650px;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.6fr);
    gap: 4rem;
    align-items: center;
    padding-block: 4rem;
  }
  .hero h1 {
    margin: 0.7rem 0 1.3rem;
    font-size: clamp(3.2rem, 9vw, 6.8rem);
    line-height: 0.95;
    letter-spacing: -0.065em;
  }
  .hero-lede {
    max-width: 750px;
    color: var(--muted);
    font-size: clamp(1.05rem, 2.1vw, 1.28rem);
    line-height: 1.7;
  }
  .availability {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--muted);
    font-size: 0.83rem;
  }
  .availability span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #35a66f;
    box-shadow: 0 0 0 4px color-mix(in srgb, #35a66f 15%, transparent);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2rem;
  }
  .hero-signal {
    position: relative;
    overflow: hidden;
    padding: 1.2rem;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 16px;
    transform: rotate(-2deg);
    box-shadow: var(--shadow);
  }
  .hero-signal::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.35;
    pointer-events: none;
  }
  .signal-label {
    position: relative;
    z-index: 1;
    display: block;
    margin-bottom: 1.2rem;
    color: var(--muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .signal-row {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }
  .signal-row.offset {
    margin-left: 1.6rem;
  }
  .signal-row span {
    padding: 0.42rem 0.65rem;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 8px;
    font:
      600 0.74rem ui-monospace,
      monospace;
  }
  .focus-strip {
    border-block: 1px solid var(--line);
    background: var(--surface);
  }
  .focus-inner {
    display: grid;
    grid-template-columns: 220px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-block: 1.6rem;
  }
  .focus-inner h2,
  .focus-inner .eyebrow {
    margin: 0;
  }
  .focus-inner > p {
    color: var(--muted);
    margin: 0;
    font-size: 0.92rem;
  }
  .focus-inner svg {
    color: var(--accent);
  }
  .direction-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .direction-card {
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 14px;
  }
  .direction-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--line);
    background: var(--surface-2);
    border-radius: 10px;
    color: var(--accent);
  }
  .direction-card h3 {
    margin: 2rem 0 0.5rem;
    font-size: 1rem;
  }
  .direction-card p,
  .project-feature p,
  .writing-cta > p {
    color: var(--muted);
    margin: 0;
  }
  .project-feature {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
    padding: 1.7rem 0;
    border-block: 1px solid var(--line);
  }
  .project-feature-list {
    border-top: 1px solid var(--line);
  }
  .project-feature {
    border-bottom: 1px solid var(--line);
  }
  .project-feature h3 {
    font-size: 1.3rem;
    margin: 0.3rem 0;
  }
  .project-period {
    color: var(--accent);
    font:
      600 0.75rem ui-monospace,
      monospace;
  }
  .project-entry {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.75rem;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 650;
  }
  .tech-list {
    display: flex;
    gap: 0.4rem;
  }
  .tech-list span {
    padding: 0.22rem 0.55rem;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.72rem;
  }
  .writing-cta {
    max-width: 800px;
  }
  .writing-cta h2 {
    margin: 0.4rem 0 0.8rem;
    font-size: clamp(1.8rem, 5vw, 3rem);
    letter-spacing: -0.04em;
  }
  @media (max-width: 760px) {
    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
      padding-top: 5rem;
    }
    .hero-signal {
      display: none;
    }
    .focus-inner {
      grid-template-columns: 1fr auto;
    }
    .focus-inner > p {
      grid-column: 1 / -1;
      grid-row: 2;
    }
    .direction-grid,
    .project-feature {
      grid-template-columns: 1fr;
    }
  }
</style>
