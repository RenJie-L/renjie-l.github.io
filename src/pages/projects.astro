---
import { ArrowRight, ExternalLink } from '@lucide/astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
const projects = await getCollection('projects');
---

<BaseLayout title="项目" description="Renjie 的工程与研究项目。" hasTranslation>
  <div class="page-intro">
    <div class="container">
      <p class="eyebrow">Projects</p><h1>项目</h1><p>
        从研究问题到工程落地：关注技术怎样变成可验证、可维护的真实成果。
      </p>
    </div>
  </div>
  <section class="project-list container">
    {
      projects.map((project) => (
        <article
          class:list={[
            'project-card',
            { 'has-cover': Boolean(project.data.cover) },
          ]}
        >
          <>
            {project.data.cover && (
              <a
                class="project-cover"
                href={project.data.links[0]?.url}
                aria-label={`进入${project.data.title}`}
              >
                <img
                  src={project.data.cover.src}
                  alt={project.data.cover.alt}
                  loading="lazy"
                />
              </a>
            )}
            <div class="project-head">
              <>
                <div>
                  <>
                    <span>
                      {project.data.period} · {project.data.role}
                    </span>
                    <h2>{project.data.title}</h2>
                    <p>{project.data.description}</p>
                  </>
                </div>
                <div class="project-links">
                  {project.data.links.map((link) => (
                    <a
                      class:list={[
                        'project-action',
                        { secondary: link.url.startsWith('http') },
                      ]}
                      href={link.url}
                      target={
                        link.url.startsWith('http') ? '_blank' : undefined
                      }
                      rel={
                        link.url.startsWith('http') ? 'noreferrer' : undefined
                      }
                    >
                      {link.label}
                      {link.url.startsWith('http') ? (
                        <ExternalLink size={14} />
                      ) : (
                        <ArrowRight size={14} />
                      )}
                    </a>
                  ))}
                </div>
              </>
            </div>
            <ul>
              {project.data.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
            <div class="technologies">
              {project.data.technologies.map((item) => (
                <span>{item}</span>
              ))}
            </div>
          </>
        </article>
      ))
    }
  </section>
</BaseLayout>
<style>
  .project-list {
    display: grid;
    gap: 1.25rem;
    padding-top: 3rem;
  }
  .project-card {
    --card-padding: clamp(1.4rem, 4vw, 2.2rem);
    overflow: hidden;
    padding: var(--card-padding);
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--surface);
  }
  .project-card.has-cover {
    display: block;
  }
  .project-cover {
    display: block;
    overflow: hidden;
    margin: calc(var(--card-padding) * -1);
    margin-bottom: var(--card-padding);
    aspect-ratio: 1200 / 630;
    background: var(--surface-2);
  }
  .has-cover .project-cover {
    position: relative;
    margin: calc(var(--card-padding) * -1);
    margin-bottom: 0;
    aspect-ratio: 1200 / 630;
  }
  .has-cover .project-cover::after {
    position: absolute;
    inset: 50% 0 0;
    background: linear-gradient(to bottom, transparent 0%, var(--surface) 100%);
    content: '';
    pointer-events: none;
  }
  .project-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-cover:hover img {
    transform: scale(1.025);
  }
  .project-head {
    display: block;
  }
  .has-cover .project-head {
    position: relative;
    z-index: 1;
    margin-top: clamp(-7rem, -10vw, -5rem);
  }
  .project-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin-top: 1rem;
  }
  .project-action {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.42rem 0.8rem;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    border-radius: 9px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 650;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }
  .project-action:hover {
    border-color: color-mix(in srgb, var(--accent) 48%, var(--line));
    transform: translateY(-1px);
  }
  .project-action.secondary {
    min-height: auto;
    padding: 0.35rem 0.1rem;
    border: 0;
    background: transparent;
    color: var(--muted);
    font-weight: 560;
  }
  .project-action.secondary:hover {
    color: var(--text);
  }
  .project-head span {
    color: var(--accent);
    font:
      600 0.78rem ui-monospace,
      monospace;
  }
  .project-card h2 {
    margin: 0.45rem 0;
    font-size: 1.45rem;
    letter-spacing: -0.025em;
  }
  .project-card p {
    max-width: 700px;
    color: var(--muted);
    margin: 0;
  }
  .project-card ul {
    padding-left: 1.25rem;
    margin: 1.7rem 0;
    color: var(--muted);
  }
  .has-cover > ul {
    margin: 1.35rem 0;
  }
  .technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }
  .technologies span {
    color: var(--muted);
    font-size: 0.78rem;
  }
  .technologies span:not(:last-child)::after {
    content: ' /';
    color: var(--line);
  }
  @media (max-width: 640px) {
    .has-cover .project-head {
      margin-top: -4.5rem;
    }
  }
</style>
